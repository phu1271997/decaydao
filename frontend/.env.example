# Copy to .env.local for local dev, or set these in Vercel Project Settings.
# The contract address you get AFTER deploying contracts/decaydao.py on GenLayer Studio.
VITE_CONTRACT_ADDRESS=0xYourDeployedContractAddressHere

# Optional: override the RPC. Defaults to hosted Studio.
# Hosted Studio (default): https://studio.genlayer.com/api
# Local Studio:            http://127.0.0.1:4000/api
# VITE_GENLAYER_RPC=https://studio.genlayer.com/api
